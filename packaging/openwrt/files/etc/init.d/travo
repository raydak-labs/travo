#!/bin/sh /etc/rc.common
# travo init script (procd)

START=99
STOP=10

USE_PROCD=1
PROG=/usr/bin/travo

start_service() {
    local enabled port auth_config_path

    config_load travo
    config_get enabled main enabled '1'
    config_get port main port '80'
    config_get auth_config_path main auth_config_path '/etc/travo/auth.json'

    [ "$enabled" = "0" ] && return 0

    mkdir -p /etc/travo
    chmod 700 /etc/travo

    procd_open_instance
    procd_set_param command "$PROG"
    procd_append_param command --port "$port"
    procd_append_param command --static-dir /www/travo
    procd_append_param command --auth-config-path "$auth_config_path"
    procd_set_param respawn
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}
